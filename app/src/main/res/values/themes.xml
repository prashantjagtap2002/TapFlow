<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Theme.TapFlow" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/ios_blue</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/ios_blue</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="colorTertiary">@color/ios_green</item>
        <item name="android:colorBackground">@color/ios_background</item>
        <item name="colorSurface">@color/ios_surface</item>
        <item name="colorOnSurface">@color/ios_label</item>
        <item name="colorOnSurfaceVariant">@color/ios_secondary_label</item>
        <item name="android:statusBarColor">@color/ios_background</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">true</item>
        <item name="android:navigationBarColor">@color/ios_surface</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="o_mr1">true</item>
        <item name="bottomNavigationStyle">@style/Widget.TapFlow.BottomNav</item>
    </style>

    <!-- iOS-style flat bottom tab bar -->
    <style name="Widget.TapFlow.BottomNav" parent="Widget.Material3.BottomNavigationView">
        <item name="android:background">@color/ios_surface</item>
        <item name="itemIconTint">@color/bottom_nav_color</item>
        <item name="itemTextColor">@color/bottom_nav_color</item>
        <item name="labelVisibilityMode">labeled</item>
        <item name="elevation">0dp</item>
        <item name="android:paddingTop">4dp</item>
    </style>

    <!-- iOS-style card: white, 12dp corners, no shadow.
         Uses Material3 parent to avoid style conflicts; strokeWidth removed (not a CardView attribute). -->
    <style name="IosCard" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">12dp</item>
        <item name="cardElevation">0dp</item>
        <item name="cardBackgroundColor">@color/ios_surface</item>
    </style>

</resources>
